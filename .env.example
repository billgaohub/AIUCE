# AIUCE Environment Variables Example
# Copy this file to .env and fill in your values

# ===========================================
# API Security Configuration
# ===========================================

# API Keys for authentication (comma-separated for multiple keys)
AIUCE_API_KEYS=your-api-key-here

# Enable authentication (true/false)
AIUCE_AUTH_ENABLED=true

# Rate limit per minute per IP
AIUCE_RATE_LIMIT=100

# CORS allowed origins (comma-separated)
AIUCE_CORS_ORIGINS=*

# Log level (DEBUG, INFO, WARNING, ERROR)
AIUCE_LOG_LEVEL=INFO

# ===========================================
# LLM Provider API Keys
# ===========================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Alibaba DashScope API Key (https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=sk-your-dashscope-key

# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Google AI API Key (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key

# ===========================================
# Optional: Local Model Configuration
# ===========================================

# Ollama API endpoint (if using local models)
OLLAMA_API_BASE=http://localhost:11434

# Local MLX server (for Apple Silicon)
MLX_API_BASE=http://localhost:8080

# ===========================================
# Optional: Vector Database Configuration
# ===========================================

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-key

# ===========================================
# Optional: Monitoring & Observability
# ===========================================

# Sentry error tracking
SENTRY_DSN=your-sentry-dsn

# Prometheus metrics endpoint
PROMETHEUS_PORT=9090
